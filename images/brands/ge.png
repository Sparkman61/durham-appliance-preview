        <script>
            let pageType = '404';
            let productType = undefined;
            let globalId = undefined ;


            console.log('null');
            
            // dataLayer initialization
            setTimeout(() => {
                window.dataLayer = window.dataLayer || [];
                window.dataLayer.push({
                    'event': 'dataLayer-initialized',
                    'userId': undefined,
                    'zipCode': localStorage.getItem('postalCode') == null ? undefined : `${localStorage.getItem('postalCode')}`,
                    'suppressStrikethrough': localStorage.getItem('suppressStrikethrough ') == null ? undefined : localStorage.getItem('suppressStrikethrough ') == 'Y' ? true : false,
                    'loggedIn': 'false', //true, false
                    'productType': productType, //wall ovens, washers, room air, etc.
                    'pageType': pageType, //product landing, product article, spec, etc.
                    'storeType': 'dtc', //dtc
                    'storeId': '1000508824', //dtc001
                    'storeName': 'GE Appliances', //dtc direct to consumer
                    'bcPage': 'true', //true, false
                    'globalId':globalId
                });
            }, 5000)
           
            
            // track product impression
            document.addEventListener('productImpression', function(e) {
                if (e.detail) {
                    window.dataLayer = window.dataLayer || [];
                    window.dataLayer.push({
                        'event': 'product-impression',
                        'ecommerce': {
                            'currencyCode': e.detail.currencyCode,
                            'impressions': e.detail.productImpressions
                        }
                    });

                }
            }, false);

            // detect product clicks
            document.addEventListener('productClick', function(e) {
                if(e.detail) {
                    window.dataLayer.push({
                        'event': 'product-click',
                        'ecommerce': {
                            'currencyCode': e.detail.currencyCode,
                            'click': {
                                'actionField': {
                                    'list': e.detail.productList
                                },
                                'products':  [{
                                    'name': e.detail.productName,
                                    'id': e.detail.productId, 
                                    'price': e.detail.price,
                                    'brand': e.detail.productBrand,
                                    'category': e.detail.category,
                                    'variant': e.detail.variant,
                                    'position': e.detail.position,
                                    'dimension70': e.detail.backorder,
                                    'dimension81': e.detail.impressionLocation, // recommended products, category page, etc
                                    'dimension103': e.detail.sale,
                                    'dimension104': e.detail.clearance,
                                    'dimension120': e.detail?.ecoPart,
                                    'dimension121': e.detail?.isTpd
                                }]
                            }
                        }
                    });
                }
            });
            
            // track product details view
            
            // catch add to cart
            document.addEventListener('productAddToCart', function(e) {
                if (e.detail) {
                    window.dataLayer = window.dataLayer || [];console.log(e.detail);
                    window.dataLayer.push({
                        'event': 'add-to-cart',
                        'addToCartLocation': e.detail.addToCartLocation,
                        'cartQuantity': parseFloat(e.detail.cartQuantity) === NaN ? null :parseFloat(e.detail.cartQuantity),
                        'cartValue': parseFloat(e.detail.cartValue) === NaN ? null: parseFloat(e.detail.cartValue),
                        'ecommerce': {
                            'currencyCode': e.detail.currencyCode,
                            'add': {
                                'actionField': {
                                    'list': e.detail.productList, // Only when adding products from a product list
                                    'position': e.detail.impressionPosition, // Only when adding products from a product list
                                },
                                'products': [{
                                    'name': e.detail.productName,
                                    'id': e.detail.productId, 
                                    'price': parseFloat(e.detail.price) === NaN ? null : parseFloat(e.detail.price),
                                    'brand': e.detail.brand,
                                    'category': e.detail.category,
                                    'variant': e.detail.variant,
                                    'quantity': parseFloat(e.detail.quantity) === NaN ? null : parseFloat(e.detail.quantity), // Delta not total
                                    'dimension70': e.detail.backorder,
                                    'dimension78': e.detail.packageId,
                                    'dimension103': e.detail.sale,
                                    'dimension104': e.detail.clearance,
                                    'dimension109': e.detail.originalOrderedItem,
                                    'dimension120': e.detail?.ecoPart,
                                    'dimension121': e.detail?.isTpd
                                }]
                            }
                        }
                    });
                }
            }, false);
            
            // track remove cart
            document.addEventListener('productRemoveFromCart', function(e) {
                window.dataLayer = window.dataLayer || [];
                window.dataLayer.push({
                    'event': 'remove-from-cart',
                    'ecommerce': {
                        'currencyCode': e.detail.currencyCode,
                        'remove': {
                            'products': [{
                                'name': e.detail.productName,
                                'id': e.detail.productId, 
                                'price': parseFloat(e.detail.price) == NaN ? null : parseFloat(e.detail.price),
                                'brand': e.detail.brand,
                                'category': e.detail.category,
                                'variant': e.detail.variant,
                                'quantity': parseFloat(e.detail.quantityRemoved) == NaN ? null : parseFloat(e.detail.quantityRemoved), // Delta not total
                                'dimension70': e.detail.backorder,
                                'dimension78': e.detail.packageId,
                                'dimension103': e.detail.sale,
                                'dimension104': e.detail.clearance,
                                'dimension109': e.detail.originalOrderedItem,
                                'dimension120': e.detail?.ecoPart,
                                'dimension121': e.detail?.isTpd
                            }]
                        }
                    }
                });
            }, false);
        </script>

