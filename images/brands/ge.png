            // retrieves BC JWT if logged in, else returns GE default JWT
            function getJWT(callback) {
                // GE default JWT
                var token = 'Bearer eyJhbGciOiJIUzUxMiJ9..B2AKxNmVoF4FxOaDUasfEOhb7kV58a4ieKLJXLgJw-0a5Aw-Kp44cM3sFET_2akmIeU4KUHaA9S3A7Bqw5klhA';

                // sessionStorage for sf access token after login in
                if(window.location.href.includes('access_token')) {
                let home_url_sf_access_token = window.location.href.split('#')[1].split('=')[1].split('&')[0];

                sessionStorage.setItem("sessionSFToken", `${home_url_sf_access_token}`);
                }
                
                 // session SF Token
                var sessionSFToken = sessionStorage.getItem("sessionSFToken");
                let sf_session_access_token = `Bearer ${sessionSFToken}`

                var customer = '';
                // <a class="navUser-action gigya-login-link" href="https://geapp.my.site.com/GEA/s/mya-my-products/MyAccount"><svg><use xlink:href="#user-icon"></use></svg> Account</a>

                var keep_alive_url = 'https://geapp.my.site.com/GEA/services/apexrest/customer-idm/user/v1/profile'


                // if logged in, return BC JWT
                // else return GE default JWT
                if (customer) {

                    // ajax call for keep_alive_url
                    $.ajax({
				        type: 'get',
				        url: keep_alive_url,
				        contentType: 'application/json; charset=utf-8',
				        dataType: 'json',
				        crossDomain: true,
                        cache: false,
				        headers: {
					        Accept: 'application/json',
					        Authorization: sf_session_access_token,
					        "mode": 'cors',
					        "Access-Control-Allow-Origin": "*",
                            "cache-control": "no-cache",
				        },
				        success: response => {
                            sessionStorage.setItem('thirdPartyUserId', response.thirdPartyUserId);
                            sessionStorage.setItem('globalId' ,response.globalId);
                            sessionStorage.setItem('isEmailVerified', response.isEmailVerified);
                            sessionStorage.setItem('SFSessionId',response.sessionId);
                            localStorage.setItem('SFSessionId',response.sessionId);
                            
                        
				        }, error: error => {
                            console.log(error, "this is the error");
				        }

			        });
                    // end ajax call for keep_alive_url
                } else {
                    console.log('bc user not logged in july 23rd');
                    if (typeof callback == 'function') {
                        callback.call(this, token);
                    }
                }
            }
            //end getJWT

            // BC customer doesn't gets logged in without this code
            getJWT(function(token) {
            });
            

            

            

        </script>

