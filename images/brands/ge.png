<script>
/* For Service Whale Widget on GEA */
/* Final/Vanity domain will be https://contractorfinder.geappliances.com */
/* Interim domain is: https://preprod.geaweb.site */

$(document).ready(function () {
  $(".htb-col1-zipcode #searchsubmit").on("click", function (e) {
    var zipcode = $(this).parent().find("#zipcode").val() || "";
    window.open(
      "https://contractorfinder.geappliances.com/contractors/" +
        (zipcode ? `postal/${zipcode}` : "") +
        "?installer=true&servicer=false"
    );
  });

  var widget = $(".cfi-find-contractor-widget");
  var showErrorMessage = function () {
    $("#zip_error", widget).show();
  };

  var setDataZipStatus = function (status) {
    $("#zipcodeId", widget).attr("data-zip-valid", status);
  };

  var validateZipCode = function () {
    setDataZipStatus("false");
    var getzipcode = $("#zipcodeId", widget).val();
    var zipcodeAPI =
      "https://api.servicewhale.com/api/v2/locations/isvalidpostal?postal=" + getzipcode;
    return $.getJSON(zipcodeAPI, function (json) {
      var zip_status = json.result;
      if (zip_status == "ERROR") {
        showErrorMessage();
        setDataZipStatus("false");
      } else {
        setDataZipStatus("true");
      }
    });
  };

  $(".inner-content-header", widget).on("click", function () {
    $(this).next().toggleClass("show");
    $(".fa", this).toggleClass("fa-minus");
    $(".fa", this).toggleClass("fa-chevron-up");
  });

  $("#contra_link", widget).click(function (e) {
    e.preventDefault();
    if ($("#zipcodeId").attr("data-zip-valid") === "true") {
      var getzipcode = $("#zipcodeId").val();
      var api_contractorfinder_url =
        "https://contractorfinder.geappliances.com/contractors/postal/" +
        getzipcode +
        "?installer=true&servicer=false";
      window.open(api_contractorfinder_url);
    } else {
      showErrorMessage();
    }
  });

  var debounce;
  $("#zipcodeId", widget).keyup(function (e) {
    clearTimeout(debounce);
    e.preventDefault();
    debounce = setTimeout(function () {
      var key_code = e.keyCode;
      var getzipcode = $("#zipcodeId").val();
      if (getzipcode.length < 3) return;
      $("#zip_error", widget).hide();
      const regex =
        /(^\d{3}(-\d{4})?$)|(^[ABCEGHJKLMNPRSTVXY]{1}\d{1}[A-Z]{1} *\d{1}[A-Z]{1}\d{1}$)/gm;
      if (getzipcode.length >= 3) {
        validateZipCode();
      } else {
        showErrorMessage();
        $("#zipcodeId").attr("data-zip-valid", "false");
      }
    }, 350);
  });

  $("#zipcodeId", widget).keydown(function (e) {
    if (e.keyCode == 13) {
      e.preventDefault();
      return false;
    }
  });
  
});

</script>      <script>
        (function() {
          window.shogunVariables = {};
          window.shogunVariables.orderId = '';
        })();
      </script>


       <script type="text/plain" src="https://nebula-cdn.kampyle.com/wu/186443/onsite/embed.js"class="optanon-category-C0003"></script>

        <script>

            function cdnURL(path) {
                if(path) {
                      return `https://cdn11.bigcommerce.com/s-pacto3wrn2/stencil/9a945940-51f9-013f-8a17-2610a56a7d6f/e/e07bea50-c806-013c-8f7b-0262f6a3925f/${path}`;
                }
                return '';
            }

            // funtion to check if the customer has verified email
            function checkEmailVerification() {
                let emailVerify = sessionStorage.getItem('isEmailVerified');
                if(emailVerify == false || emailVerify == 'false') {
                    // need to write the href and click function  id="email-verify"
                    window.location.replace('/email-verification/');
                } else {
                    let teSFSessionId = sessionStorage.getItem('SFSessionId');
                    if(teSFSessionId) {
                        window.location.href=`https://geapp.my.site.com/GEA/secur/frontdoor.jsp?sid=${sessionStorage.getItem('sessionSFToken')}&retURL=%2FGEA%2Fs%2Fmya-my-products`
                    } else {
                        console.log("secondIfConditionhttps://geapp.my.site.com/GEA")
                        window.location.replace('https://geapp.my.site.com/GEA/?redirectURL=https%3A%2F%2Fwww.geappliances.com');
                    }
                }
            }

         function logOut(){
            console.log("logout Function")
              var WLlogoutsfSessionId = sessionStorage.getItem('SFSessionId');
                fetch(`https://geapp.my.site.com/GEA/services/apexrest/customer-idm/user/v1/session/${WLlogoutsfSessionId}`, {
                    method: 'DELETE', mode: 'cors'
                }).then(() => {
                window.location.replace('https://geapp.my.site.com/GEA/s/mya-logged-out');
                })
         }

            function sendUserIdmEmailVerify() {
                // ajax call for email verification
                var email_verify_url = 'https://geapp.my.site.com/GEA/services/apexrest/customer-idm/user/v1/send-verification-email'
                    let sf_email_verify_token = sessionStorage.getItem('sessionSFToken');
                    let sf_email_token = `Bearer ${sf_email_verify_token}`;
                     $.ajax({
				        type: 'post',
				        url: email_verify_url,
				        contentType: 'application/json; charset=utf-8',
				        dataType: 'json',
                        data: '{"successURL":"https://geapp.my.site.com/GEA/s/mya-my-products"}',
				        crossDomain: true,
                        cache: false,
				        headers: {
					        Accept: 'application/json',
					        Authorization: sf_email_token,
					        "mode": 'cors',
					        "Access-Control-Allow-Origin": "*",
                            "cache-control": "no-cache",
				        },
				        success: response => {
				        	console.log("Verification email sent", response);
				        }, error: error => {
                            console.log("Send email verification failed", error);
				        }
			        });
            }
            
            var emailVerificationButton = document.querySelector('#email-verify');
            if(emailVerificationButton) {
                emailVerificationButton.onclick = function() {
                    sendUserIdmEmailVerify();
                    window.location.replace('/email-reverification/');
                }
            }

            var emailReVerificationButton = document.querySelector('#email-reverify');
            if(emailReVerificationButton) {
                emailReVerificationButton.onclick = function() {
                    sendUserIdmEmailVerify();
                }
            }
            
            if (window.performance.navigation.type != 1) {
                var logoutsfSessionId = sessionStorage.getItem('SFSessionId');
                var localsfSessionId = localStorage.getItem('SFSessionId');
                var tesessionSFToken = sessionStorage.getItem('sessionSFToken');
                if(!tesessionSFToken && logoutsfSessionId && localsfSessionId && sessionStorage.getItem('SFSessionId')) {
                    fetch(`https://geapp.my.site.com/GEA/services/apexrest/customer-idm/user/v1/session/${logoutsfSessionId}`, { method: 'DELETE', mode: 'cors' })
                    fetch(`https://geapp.my.site.com/GEA/services/apexrest/customer-idm/user/v1/session/${localsfSessionId}`, { method: 'DELETE', mode: 'cors' })
                    fetch(`https://geapp.my.site.com/GEA/services/apexrest/customer-idm/user/v1/session/${sessionStorage.getItem('SFSessionId')}`, { method: 'DELETE', mode: 'cors' })
                }
            }
            
            var reLogin = document.querySelector('#reLogin');
            if(reLogin) {
                reLogin.onclick = function() {
                    window.location.replace('https://geapp.my.site.com/GEA/?redirectURL=https%3A%2F%2Fwww.geappliances.com');
                }
            }
            
            var loginLinks = document.querySelectorAll('.sf-login-link');
            var currentPath = encodeURIComponent(window.location.href);
            if(loginLinks) {
                for (var i = 0; i < loginLinks.length; i++) {
                    loginLinks[i].setAttribute('href', loginLinks[i].getAttribute('href') + '?redirectURL=' + currentPath);
                }
            }
                        
        </script>
    </body>
</html>
